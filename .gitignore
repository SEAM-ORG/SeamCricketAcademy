opencode.json
opencode.jsonc
tui.json
tui.jsonc

# Machine/agent skill dumps — not product source
.agents/

# OpenSpec host adapters (commands delivery) — track opsx only; ignore other harness junk
.opencode/*
!.opencode/commands/
!.opencode/commands/**
.gemini/*
!.gemini/commands/
!.gemini/commands/**
.agent/*
!.agent/workflows/
!.agent/workflows/**
